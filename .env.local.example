# === Gemini API (1.5 Pro) ===
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# === AliExpress Open Platform ===
# https://portals.aliexpress.com  ->  Tools -> API
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=default

# === Supabase ===
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Public site ===
NEXT_PUBLIC_SITE_URL=https://fixfind.cc

# === Optional: Google AdSense ===
NEXT_PUBLIC_ADSENSE_CLIENT=

# === 측정 / SEO 소유확인 (measurement) ===
# GA4 측정 ID: https://analytics.google.com  -> 관리 -> 데이터 스트림 -> "G-XXXXXXXXXX"
NEXT_PUBLIC_GA_ID=
# 구글 서치콘솔 HTML 태그 인증값 (content="..." 안의 값만):
# https://search.google.com/search-console  -> 속성추가 -> URL접두어 -> HTML 태그
GOOGLE_SITE_VERIFICATION=
# 네이버 서치어드바이저 사이트 인증값 (content="..." 안의 값만):
# https://searchadvisor.naver.com  -> 웹마스터도구 -> 사이트등록 -> HTML 태그
NAVER_SITE_VERIFICATION=

# === Cron auth ===
# setup.ps1 auto-generates this. Or: openssl rand -hex 32
CRON_SECRET=
